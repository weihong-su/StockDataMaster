# ─── Python 缓存 ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
# 例外：lib/xtquant 的 .pyd 文件需要提交（开箱即用）
!lib/xtquant/*.pyd

# ─── 虚拟环境 ─────────────────────────────────────────────────────────────────
.env
.venv
env/
venv/

# ─── 日志文件 ─────────────────────────────────────────────────────────────────
/logs/*
!logs/.gitkeep

# ─── 文档（本地生成，不提交）──────────────────────────────────────────────────
/docs/*

# ─── 测试文件（旧的独立测试脚本保留，但不追踪旧pycache）─────────────────────
# 注意：test/suite/ 目录（pytest框架）应全部提交

# ─── 缓存数据库 ───────────────────────────────────────────────────────────────
cache/*.db
cache/*.db-shm
cache/*.db-wal

# ─── 备份文件 ─────────────────────────────────────────────────────────────────
*.backup
*.bak

# ─── 系统文件 ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
nul

# ─── IDE ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── 测试报告和临时文件 ───────────────────────────────────────────────────────
test/reports/
.pytest_cache/
*.egg-info/
dist/
build/

# ─── spec-workflow 模板（不需要提交）────────────────────────────────────────
.spec-workflow/config.example.toml
.spec-workflow/templates/
.spec-workflow/user-templates/README.md
.playwright-mcp/
