# StockDataMaster 本地环境变量模板
# 复制为 .env 后填写真实值；.env 已被 .gitignore 忽略，不应提交。

TUSHARE_TOKEN=your_tushare_token_here

# 可选：baostock 0.9.x API Key（留空则匿名访问，旧版 0.8.x 自动跳过）
BAOSTOCK_API_KEY=

# 可选：QMT/xtquant 本地配置
XTQUANT_QMT_PATH=
XTQUANT_ACCOUNT=

# 可选：日志配置
STOCKDATAMASTER_LOG_LEVEL=INFO
STOCKDATAMASTER_LOG_FILE=logs/data_master.log
